principals:
  - slug: operator
    display_name: Operator
    kind: person
    notes: Personal principal and operator identity.
  - slug: kubicki-trust
    display_name: Kubicki Trust
    kind: trust
    notes: Trust-owned Evergreen assets and related operations.
  - slug: openbrand
    display_name: OpenBrand
    kind: company
    notes: Work/company operational boundary.
  - slug: parkergale
    display_name: PEF
    kind: company
    notes: Private Equity Funbot principal. ParkerGale and PEFB remain valid aliases for the confidential finance and deal-work boundary.
  - slug: tcg
    display_name: TCG
    kind: company
    notes: Separate business boundary.
  - slug: yhix
    display_name: Yhix
    kind: venture
    notes: Studio and experiments.

policy_profiles:
  - slug: read-only
    display_name: Read Only
    mode: read-only
    requires_approval: false
    allows_outbound_send: false
    allows_runtime_control: false
    allows_side_effects: false
    powers:
      mouth: none
      purse: none
      seal: none
      key:
        level: read
        lease_source: Norman Keys
        revoker: norman-keys
        revocation_tested_at: 2026-05-31
        revocation_test_notes: Norman Keys dummy read-only lease drill passed at 2026-05-31T01:44:03Z; issued and revoked drill alias drill.read-only.key-revocation for research-analyst without raw secret output.
      sword: none
  - slug: draft-first
    display_name: Draft First
    mode: draft-first
    requires_approval: true
    allows_outbound_send: true
    allows_runtime_control: false
    allows_side_effects: false
    powers:
      mouth:
        level: draft
        revoker: norman
        revocation_tested_at: pending
      purse: none
      seal: none
      key:
        level: limited
        lease_source: Norman Keys
        revoker: norman-keys
        revocation_tested_at: pending
      sword: none
  - slug: manual
    display_name: Manual
    mode: manual
    requires_approval: true
    allows_outbound_send: true
    allows_runtime_control: true
    allows_side_effects: true
    powers:
      mouth:
        level: operator-approved
        revoker: norman
        revocation_tested_at: pending
      purse: none
      seal: none
      key:
        level: scoped
        lease_source: Norman Keys
        revoker: norman-keys
        revocation_tested_at: pending
      sword: none
  - slug: shared
    display_name: Shared
    mode: shared
    requires_approval: false
    allows_outbound_send: true
    allows_runtime_control: true
    allows_side_effects: true
    powers:
      mouth:
        level: limited
        revoker: norman
        revocation_tested_at: 2026-05-31
        revocation_test_notes: Routing action-hold Mouth drill passed at 2026-05-31T11:33:18Z; L1 blocked outbound queueing for event 94336 with no job, then restored L0 queued event 94337 and parked its proof job before delivery.
      purse: none
      seal: none
      key:
        level: limited
        lease_source: Norman Keys
        revoker: norman-keys
        revocation_tested_at: pending
      sword: none
  - slug: auto
    display_name: Auto
    mode: auto
    requires_approval: false
    allows_outbound_send: true
    allows_runtime_control: true
    allows_side_effects: true
    powers:
      mouth:
        level: limited
        revoker: norman
        revocation_tested_at: pending
      purse: none
      seal: none
      key:
        level: limited
        lease_source: Norman Keys
        revoker: norman-keys
        revocation_tested_at: pending
      sword: none
  - slug: panic-lock
    display_name: Panic Lock
    mode: manual
    requires_approval: true
    allows_outbound_send: false
    allows_runtime_control: false
    allows_side_effects: false
    powers:
      mouth: none
      purse: none
      seal: none
      key: none
      sword: none

