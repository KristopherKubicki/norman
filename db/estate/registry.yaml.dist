    principal: operator
    domain: operator-knowledge
    display_name: Norman
    class: manager
    policy_profile: manual
    notes: Cross-principal general manager; service implementation remains editable.
  - slug: evergreen-ops
    principal: kubicki-trust
    domain: kubicki-evergreen
    display_name: Evergreen Ops
    class: operator
    policy_profile: shared
  - slug: household-ops
    principal: operator
    domain: operator-household
    display_name: Household Ops
    class: operator
    policy_profile: shared
  - slug: communications
    principal: operator
    domain: operator-communications
    display_name: Communications
    class: router
    policy_profile: draft-first
