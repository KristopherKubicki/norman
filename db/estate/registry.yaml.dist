    principal: operator
    domain: operator-security
    display_name: Cyber Advisor
    class: advisor
    policy_profile: manual
  - slug: archivist
    principal: operator
    domain: operator-knowledge
    display_name: Archivist
    class: archivist
    policy_profile: auto
  - slug: observability
    principal: operator
    domain: operator-observability
    display_name: Observability
    class: observer
    policy_profile: shared
  - slug: research-analyst
    principal: openbrand
    domain: openbrand-knowledge
    display_name: Research Analyst
    class: advisor
    policy_profile: read-only
  - slug: finance-reader
    principal: operator
    domain: operator-finance
    display_name: Finance Reader
    class: advisor
    policy_profile: read-only
  - slug: health-reader
    principal: operator
    domain: operator-health
    display_name: Health Reader
    class: advisor
    policy_profile: read-only
    notes: Private health monitoring by default; summarize sparingly and require deliberate entry for details.
  - slug: parkergale-reader
    principal: parkergale
    domain: parkergale-private
    display_name: PEF
    class: advisor
    policy_profile: read-only
    notes: Private Equity Funbot. Aliases ParkerGale, PEF, and PEFB. Confidential financial and deal-work advisor; keep hidden from ordinary fleet surfaces.
  - slug: radio-supervisor
    principal: operator
    domain: operator-radio
    display_name: Radio Supervisor
    class: operator
    policy_profile: manual
  - slug: scheduler
    principal: operator
    domain: operator-scheduling
    display_name: Scheduler
    class: advisor
    policy_profile: draft-first
  - slug: null-agent
    principal: yhix
    domain: yhix-cloud
    display_name: Null Agent
    class: yhix
    policy_profile: shared
    notes: Game/TUI bot lane for the Null Agent project. Treat Yhix bots as a separate class from household, work, and shared infrastructure bots.

workers:
  - slug: hal
    principal: operator
    display_name: Hal
    kind: workstation
    hostname: hal
    place: house
    control_class: root-controlled
    policy_profile: shared
  - slug: toy-box
    principal: operator
    display_name: Toy Box
    kind: server
    hostname: toy-box
    place: house
    control_class: root-controlled
    policy_profile: shared
    bbs:
      role: personal
      zone: personal
      receive: true
      full_coverage: false
      cross_zone: false
      allow_private: false
      channels:
        - switchboard
        - personal
        - personal/*
  - slug: private-host
    principal: operator
    display_name: Private Host
    kind: container
    hostname: private
    place: house
    control_class: root-controlled
    policy_profile: manual
    bbs:
      role: private
      zone: private
      receive: true
      full_coverage: true
      cross_zone: true
      allow_private: true
      channels:
        - switchboard
        - private
        - private/*
        - personal/*
        - work/*
        - network/*
    notes: Dedicated Proxmox LXC enclave for finance, health, and other confidential bots. Live at 192.168.0.148. Do not mix with ordinary Personal or Shared fleet runtimes.
  - slug: norman-host
    principal: operator
    display_name: Norman Host
    kind: container
    hostname: norman
    place: house
    control_class: root-controlled
    policy_profile: manual
    bbs:
      role: broker
      zone: root
      receive: true
      full_coverage: true
      cross_zone: true
      allow_private: true
      channels:
        - "*"
  - slug: phobos-host
    principal: operator
    display_name: Phobos Host
    kind: edge
    place: house
    control_class: root-controlled
    policy_profile: manual
  - slug: networking-host
    principal: operator
    display_name: Networking Host
    kind: vm
    hostname: networking
    place: house
    control_class: root-controlled
    policy_profile: manual
    bbs:
      role: network
      zone: network
      receive: true
      full_coverage: true
      cross_zone: false
      allow_private: false
      channels:
        - switchboard
        - network
        - network/*
        - dns
        - caddy
        - tailnet
  - slug: quaoar
    principal: kubicki-trust
    display_name: Quaoar
    kind: edge
    place: beach
    control_class: admin-controlled
    policy_profile: manual
  - slug: openbrand-work-service-node
    principal: openbrand
    display_name: Work Special
    kind: container
    hostname: work-special
    place: house
    control_class: pending-control
    policy_profile: shared
    bbs:
      role: work
      zone: work
      receive: true
      full_coverage: false
      cross_zone: false
      allow_private: false
      channels:
        - switchboard
        - work
        - work/*
  - slug: yhix-cloud
    principal: yhix
    display_name: Yhix Cloud
    kind: cloud
    hostname: yhix-cloud
    control_class: pending-control
    policy_profile: shared
    bbs:
      role: yhix
      zone: yhix
      receive: true
      full_coverage: false
      cross_zone: false
      allow_private: false
      channels:
        - switchboard
        - yhix
        - yhix/*

