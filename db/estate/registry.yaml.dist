        revoker: norman
        revocation_tested_at: pending
      sword:
        level: operator-approved
        responsible_human: operator or designated HR/account owner
        accountable_purpose: Ticketed employee offboarding, lockout, account-risk containment, and access-revocation execution only.
        constraints:
          - Explicit operator command required.
          - Ticket or accountable request context required.
          - No autonomous termination, lockout, offboarding, notice, or employment-impacting action.
          - Report every affected account, command, system, and rollback/reopen path.
        revoker: norman
        revocation_tested_at: pending
    console_url: https://infra.kris.openbrand.com/
    console_url_tailnet: http://work-special.tail94915.ts.net:8782/
