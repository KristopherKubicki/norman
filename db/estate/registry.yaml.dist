principals:
  - slug: kristopher
    display_name: Kristopher
    kind: person
    notes: Personal principal and operator identity.
  - slug: kubicki-trust
    display_name: Kubicki Trust
    kind: trust
    notes: Trust-owned Evergreen assets and related operations.
  - slug: openbrand
    display_name: OpenBrand
    kind: company
    notes: Work/company operational boundary.
  - slug: parkergale
    display_name: PEFB
    kind: company
    notes: Private Equity Funbot principal. PEFB is the primary bot-facing name; ParkerGale and PEF remain compatibility aliases for the confidential finance and deal-work boundary.
  - slug: tcg
    display_name: TCG
    kind: company
    notes: Separate business boundary.
  - slug: yhix
    display_name: Yhix
    kind: venture
    notes: Studio and experiments.

policy_profiles:
  - slug: read-only
    display_name: Read Only
    mode: read-only
    requires_approval: false
    allows_outbound_send: false
    allows_runtime_control: false
    allows_side_effects: false
  - slug: draft-first
    display_name: Draft First
    mode: draft-first
    requires_approval: true
    allows_outbound_send: true
    allows_runtime_control: false
    allows_side_effects: false
  - slug: manual
    display_name: Manual
    mode: manual
    requires_approval: true
    allows_outbound_send: true
    allows_runtime_control: true
    allows_side_effects: true
  - slug: shared
    display_name: Shared
    mode: shared
    requires_approval: false
    allows_outbound_send: true
    allows_runtime_control: true
    allows_side_effects: true
  - slug: auto
    display_name: Auto
    mode: auto
    requires_approval: false
    allows_outbound_send: true
    allows_runtime_control: true
    allows_side_effects: true
  - slug: panic-lock
    display_name: Panic Lock
    mode: manual
    requires_approval: true
    allows_outbound_send: false
    allows_runtime_control: false
    allows_side_effects: false

control_classes:
  - slug: root-controlled
    display_name: Root Controlled
    rank: 100
  - slug: admin-controlled
    display_name: Admin Controlled
    rank: 80
  - slug: pending-control
    display_name: Pending Control
    rank: 40
  - slug: observed-only
    display_name: Observed Only
    rank: 10

