{
  "schema": "norman.prompt-bad-route-corpus.v1",
  "version": "2026.07.15.terse-operator-commands",
  "description": "Stateful terse prompts that previously risked drifting to cloud/default routes. These are regression fixtures for the Norman prompt load balancer.",
