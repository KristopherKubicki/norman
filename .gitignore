# .gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyc
.Python
env/
venv/
.venv/
*.log

# Alembic
#  all alembic migrations are live now
#alembic/versions/

# Jupyter Notebook
.ipynb_checkpoints/

# VSCode
.vscode/

# PyCharm
.idea/

# MacOS
.DS_Store

# Environment variables
.env
.env.*
*.env
!.env.example
!*.env.example

# Local/private security material
docs/secrets_inventory.md
docs/*secrets_inventory*.md
docs/*secret*inventory*.md
private/
.private/
*.credentials
*.token
*.key
*.pem
*.p12
*.pfx
*.jks
*.kubeconfig

# old files
*.old
*.dead
*.ignore
*.orig
*.bak-*
*.bak.*

# logs
logs/

# config file
config.yaml
db/hypervisor/apps.yaml
db/hypervisor/state/
db/estate/registry.yaml
db/tmux_profiles/*/running_now.json

# local/generated artifacts
node_modules/
.pytest_cache/
.hypothesis/
.backup/
.codex-backups/
.session
tmp/
tmp_console_audit_stage/
app_tmp_bundle/
norman.egg-info/
*.db
*.db-shm
*.db-wal
db/*.db.backup-*
db/*.db.bak-*


*.sw[op]

# ignore user databases
db/*.db
coverage.xml
